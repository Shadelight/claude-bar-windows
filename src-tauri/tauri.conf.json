{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Bar",
  "version": "0.1.0",
  "identifier": "com.daybi.claudebar",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Bar",
        "width": 600,
        "height": 440,
        "minWidth": 340,
        "minHeight": 150,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "visible": true,
        "center": true,
        "windowEffects": {
          "effects": ["acrylic"],
          "state": "active",
          "radius": 14,
          "color": [16, 20, 40, 210]
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
